{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": true
  },
  "include": ["__tests__", "cjs", "esm", "src", "*.mjs", "*.mts", "*.ts"]
}
